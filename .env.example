# Rename this file to .env and fill in your values

# Required: Google Gemini API key
GEMINI_API_KEY=your_api_key_here

# Optional: Model name (default: gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-pro

# Optional: Max upload size in MB (Flask MAX_CONTENT_LENGTH)
MAX_CONTENT_LENGTH_MB=2

# Optional: Allowed file extensions for upload
ALLOWED_EXTENSIONS=txt

# Optional: Flask secret key (auto-generated if not set)
SECRET_KEY=
